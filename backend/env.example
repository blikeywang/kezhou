# 后端环境变量(复制为 .env,勿提交仓库)。所有密钥只放这里 / 密管。
ENV=dev
JWT_SECRET=用强随机串替换
PUBLIC_DOMAIN=http://localhost:5173

# ---- Stripe(Billing 订阅)· 当前"即将支持",接好后置 1 ----
STRIPE_ENABLED=0
# 【机密】secret key 只你自己填,勿分享、勿入库:
STRIPE_SECRET_KEY=sk_test_你的私钥
STRIPE_WEBHOOK_SECRET=whsec_你的Webhook签名密钥
STRIPE_PRICE_PRO=price_你的Pro价格ID
STRIPE_API_VERSION=2026-06-24.dahlia
# 注:publishable key(pk_test_...)属于前端,不放后端 —— 见 ../frontend/env.example

# ---- 支付演示开关:上线设 0(启用真实链上核验)----
PAYMENTS_DEMO=0

# ---- 加密收款(多链 USDC;收款地址已在 app/config.py 配置好)----
# 仅需按需覆盖各链 RPC(默认用公共节点,生产建议换自有/付费节点):
BNB_RPC=https://bsc-dataseed.binance.org
ARB_RPC=https://arb1.arbitrum.io/rpc
SOL_RPC=https://api.mainnet-beta.solana.com
